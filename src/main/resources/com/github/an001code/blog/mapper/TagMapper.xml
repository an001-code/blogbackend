<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.an001code.blog.mapper.TagMapper">

    <select id="getTagList" resultType="com.github.an001code.blog.pojo.Tag">
        SELECT *
        FROM tag
        <where>
            <!-- 按状态过滤 -->
            <if test="status != null">
                AND status = #{status}
            </if>
            <!-- 按时间范围过滤（注意：建议分开判断 begin 和 end） -->
            <if test="begin != null and begin != ''">
                AND DATE(updated_at) >= #{begin}
            </if>
            <if test="end != null and end != ''">
                <![CDATA[
                AND DATE(updated_at) <= #{end}
                ]]>
            </if>
        </where>
        ORDER BY updated_at DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="tagId">
        insert into tag(tag_name, status)
        values (#{tagName}, #{status})
    </insert>

    <update id="update" useGeneratedKeys="true" keyProperty="tagId">
        update tag
        <set>
            <if test="tagName != null and tagName != ''">
                tag_name = #{tagName},
            </if>
            <if test="useCount != null">
                use_count = #{useCount},
            </if>
            <if test="status != null">
                status = #{status}
            </if>
        </set>
        where tag_id = #{tagId}
    </update>

    <delete id="delete">
        delete from tag
        where tag_id in
        <foreach collection="ids" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
    </delete>
</mapper>